// Prisma Schema - cme-checklist
// Seguindo padrão do logistica_pessoal_app_portal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StatusItem {
  OK
  PENDENTE
  NAO_APLICAVEL
}

enum StatusInspecao {
  EM_ANDAMENTO
  CONCLUIDA
  VALIDADA
  CANCELADA
}

enum TipoInspecao {
  PRE_EMBARQUE
  OPERACIONAL
  RETORNO_EMBARQUE
}

model User {
  id        String   @id @default(uuid())
  nome      String
  cpf       String?  @unique
  email     String?  @unique
  funcao    String?
  senhaHash String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inspecoesCriadas     Inspecao[] @relation("InspecaoCriadaPor")
  inspecoesValidadas   Inspecao[] @relation("InspecaoValidadaPor")
  respostasRegistradas RespostaItem[] @relation("RespostaRegistradaPor")
  respostasAtualizadas RespostaItem[] @relation("RespostaAtualizadaPor")
}

model Equipamento {
  id          String   @id @default(uuid())
  codigo      String   @unique // código canônico (com hífen) — chave de negócio
  codigoExibicao String?       // código original da planilha
  chaveBusca  String?          // normalizado (só alfanumérico) p/ busca inteligente
  nome        String
  tipo        String   // After Cooler, Compressor, etc.
  fabricante  String?
  localizacao String?
  localizacaoAtual String?     // coluna ATUAL da planilha
  estado      String?
  status      String?  // Ativo, Manutenção, etc.
  statusLiberacao String @default("PENDENTE") // PENDENTE | LIBERADO | VENCIDO
  validadeCertificado DateTime?
  arquivoCertDriveUrl String?
  dadosPlanilha Json?          // preserva TODAS as colunas da planilha (p/ a Logística)
  syncStatus  String?  @default("IMPORTADO")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inspecoes   Inspecao[]
  certificados Certificado[]

  @@index([chaveBusca])
  @@index([tipo])
}

model Certificado {
  id            String   @id @default(uuid())
  equipamentoId String
  tipo          String   // EQUIPAMENTO | ESLINGA | PSV | MANOMETRO | NR13 | CONTAINER ...
  numero        String?
  emissao       DateTime?
  validade      DateTime?
  orgaoEmissor  String?
  arquivoUrl    String?
  createdAt     DateTime @default(now())

  equipamento   Equipamento @relation(fields: [equipamentoId], references: [id], onDelete: Cascade)

  @@index([equipamentoId])
}

model ChecklistModelo {
  id          String   @id @default(uuid())
  nome        String
  tipoEquipamento String
  versao      Int      @default(1)
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())

  itens ItemChecklist[]
  inspecoes Inspecao[]

  @@index([tipoEquipamento, ativo])
}

model ItemChecklist {
  id          String   @id @default(uuid())
  modeloId    String
  secao       String   // Ex: "INSPEÇÃO GERAL", "SISTEMA PNEUMÁTICO", etc.
  descricao   String
  ordem       Int
  obrigatorio Boolean  @default(true)
  tipo        String   @default("STATUS") // STATUS | CERTIFICADO | MEDICAO | TEXTO
  unidade     String?  // p/ MEDICAO: '°C', 'A', 'bar'

  modelo ChecklistModelo @relation(fields: [modeloId], references: [id], onDelete: Cascade)
  respostas  RespostaItem[]

  @@index([modeloId]) // bootstrap puxa os itens por modelo
}

model Inspecao {
  id            String   @id @default(uuid())
  equipamentoId String
  tipo          TipoInspecao
  data          DateTime @default(now())
  updatedAt     DateTime @updatedAt
  numeroDocumento String? @unique // registro único rastreável (ISO 9001)
  modeloId      String?  // versão do template usada (ISO 9001 — rastreabilidade)
  modeloVersao  Int?
  responsavelGeral String?  // Nome do responsável principal
  localizacao   String?
  status        StatusInspecao @default(EM_ANDAMENTO)
  observacoesGerais String?
  createdById   String?
  validadaPorId String?
  validadaEm    DateTime?
  assinaturaUrl   String?   // URL do Drive (substitui assinaturaBase64)
  fotosUrls       String[]  // Array de URLs do Drive (substitui fotosEquipamento)
  videoUrl        String?   // Vídeo geral do equipamento (separado de fotosUrls)
  origem          String?
  destino         String?
  compressorUtilizado String?
  classificacao   String?

  equipamento Equipamento @relation(fields: [equipamentoId], references: [id])
  modelo      ChecklistModelo? @relation(fields: [modeloId], references: [id])
  createdBy   User?       @relation("InspecaoCriadaPor", fields: [createdById], references: [id])
  validadaPor User?       @relation("InspecaoValidadaPor", fields: [validadaPorId], references: [id])
  respostas   RespostaItem[]
  materiais   MaterialUtilizado[]

  @@index([equipamentoId, data])
  @@index([createdById, status]) // Home do app: GET /inspecoes/mine
}

model RespostaItem {
  id          String   @id @default(uuid())
  inspecaoId  String
  itemId      String
  status      StatusItem?  // opcional: MEDICAO/TEXTO não têm OK/Pendente/N-A
  observacao  String?
  responsavel String?  // Quem executou aquela tarefa específica (elétrica, pintura, etc.)
  valorNumerico Float?   // MEDICAO (temperatura, amperagem)
  valorTexto    String?  // TEXTO (observações livres)
  createdById String?
  fotoUrl         String?   // URL do Drive (legado: foto única — mantido p/ compat)
  fotosUrls       String[]  @default([]) // evidências por pergunta (até 6)
  videoUrl        String?   // vídeo de evidência (separado de fotosUrls)
  fotoResolvidaUrl String?  // URL do Drive (substitui fotoResolvidaBase64)
  certificadoId   String?
  certificadoValidade String?
  pendenciaResolvida  Boolean?
  updatedById String?           // último usuário logado que alterou a resposta
  updatedAt   DateTime @updatedAt @default(now()) // default no banco: backfill de linhas pré-existentes

  inspecao Inspecao     @relation(fields: [inspecaoId], references: [id], onDelete: Cascade)
  item     ItemChecklist @relation(fields: [itemId], references: [id])
  createdBy User?       @relation("RespostaRegistradaPor", fields: [createdById], references: [id])
  updatedBy User?       @relation("RespostaAtualizadaPor", fields: [updatedById], references: [id])

  @@unique([inspecaoId, itemId])
}

// Histórico append-only de alterações de respostas (auditoria por campo).
// Sem FKs (como AuditLog): registro denormalizado e imutável de "quem mudou
// qual campo, de -> para, quando".
model RespostaHistorico {
  id            String   @id @default(uuid())
  inspecaoId    String
  itemId        String
  secao         String?
  campo         String   // status | valorNumerico | observacao | responsavel | ...
  valorAnterior String?
  valorNovo     String?
  responsavelDeclarado String?  // texto livre de quem fez a conferência (RespostaItem.responsavel)
  userId        String?  // usuário logado que efetuou a alteração
  userNome      String?
  criadoEm      DateTime @default(now())

  @@index([inspecaoId])
  @@index([inspecaoId, itemId])
  @@index([criadoEm])
}

model Material {
  id          String   @id @default(uuid())
  codigo      String?  @unique
  descricao   String
  unidade     String   // UN, KG, M, etc.
  categoria   String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())

  utilizadoEm MaterialUtilizado[]
}

model MaterialUtilizado {
  id          String   @id @default(uuid())
  inspecaoId  String
  materialId  String
  quantidade  Float
  observacao  String?

  inspecao Inspecao @relation(fields: [inspecaoId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])

  @@index([inspecaoId])
  @@index([materialId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  userNome   String?
  acao       String   // CRIAR_INSPECAO | VALIDAR_INSPECAO | EDITAR_TEMPLATE
  entidade   String   // INSPECAO | CHECKLIST_MODELO
  entidadeId String?
  detalhe    Json?
  criadoEm   DateTime @default(now())

  @@index([entidade, entidadeId])
  @@index([criadoEm])
}

